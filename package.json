{
  "name": "rslcollective-dashboard",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json && vite build",
    "test": "vitest",
    "check": "tsc --noEmit",
    "worker:dev": "wrangler dev --config wrangler.jsonc",
    "worker:deploy": "wrangler deploy --config wrangler.production.jsonc",
    "db:migrate:local": "wrangler d1 migrations apply rsl-collective-dashboard --local --config wrangler.jsonc",
    "db:migrate:remote": "wrangler d1 migrations apply rsl-collective-dashboard --remote --config wrangler.production.jsonc"
  },
  "dependencies": {
    "@clerk/backend": "^3.8.3",
    "@clerk/react": "^6.11.0",
    "@mantine/core": "^8.0.0",
    "@mantine/hooks": "^8.0.0",
    "@tanstack/react-query": "^5.0.0",
    "hono": "^4.0.0",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260611.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "jsdom": "^26.0.0",
    "miniflare": "4.20260611.0",
    "typescript": "^5.0.0",
    "vite": "^7.0.0",
    "vitest": "^3.0.0",
    "wrangler": "^4.0.0"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "packageManager": "pnpm@10.32.0+sha512.9b2634bb3fed5601c33633f2d92593f506270a3963b8c51d2b2d6a828da615ce4e9deebef9614ccebbc13ac8d3c0f9c9ccceb583c69c8578436fa477dbb20d70"
}
